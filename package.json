{
  "name": "selbstbehalt",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hostable, privacy-first manager for German private health insurance (PKV).",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @selbstbehalt/frontend test:e2e",
    "audit": "pnpm audit --prod --audit-level high",
    "licenses:check": "node scripts/check-licenses.mjs",
    "fees:build": "node scripts/build-fee-schedules.mjs",
    "fees:validate": "node scripts/validate-fee-schedules.mjs",
    "ocr:models": "node scripts/fetch-ocr-models.mjs",
    "ocr:wasm": "node scripts/copy-ort-wasm.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "prettier-plugin-svelte": "^4.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
