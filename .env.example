# ─────────────────────────────────────────────────────────────
# selbstbehalt — environment configuration
#
# Copy this file to `.env` and adjust the values for your setup:
#
#     cp .env.example .env
#
# `.env` (and every `.env.*` except this example) is gitignored and
# must never be committed — it may contain secrets.
# ─────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────

# Path to the SQLite database file. In Docker Compose this points at the
# mounted volume (./data/db); for local development a relative path like
# ./data/db/pkv.sqlite works too. Defaults to `data/db/pkv.sqlite` if unset.
DATABASE_PATH=/app/db/pkv.sqlite

# Port the backend HTTP server listens on (default: 8080).
PORT=8080

# Allowed CORS origins for the backend API: `*` for any (sensible on a trusted
# home network) or a comma-separated allow-list, e.g.
# `http://localhost:5173,http://nas.local:3000`.
CORS_ORIGINS=*

# Optional API key for the backend's `X-API-Key` authentication, used for
# external access via VPN (e.g. Tailscale). Leave empty when you rely solely
# on reverse-proxy Basic Auth inside your home network.
# docker-compose.yml wires this into the backend as `API_KEY=${PKV_API_KEY}`.
PKV_API_KEY=

# ── Frontend ─────────────────────────────────────────────────

# Base URL the BROWSER uses to reach the backend REST API. The frontend is a
# static, client-rendered PWA, so this value is baked into the bundle at *build
# time* (docker-compose.yml passes it to the frontend image as a build arg). It
# must therefore be an address reachable from the user's browser — NOT the
# in-compose service name `backend`, which only resolves inside the network.
#   - Same machine as the stack:  http://localhost:8080
#   - Another device on the LAN:  http://<nas-host>:8080  (or your reverse-proxy URL)
# Changing it requires rebuilding the frontend image (`docker compose build
# frontend`); alternatively override it at runtime in the app's settings.
PUBLIC_API_URL=http://localhost:8080
