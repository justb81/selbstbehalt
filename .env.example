# ─────────────────────────────────────────────────────────────
# selbstbehalt — environment configuration
#
# Copy this file to `.env` and adjust the values for your setup:
#
#     cp .env.example .env
#
# `.env` (and every `.env.*` except this example) is gitignored and
# must never be committed — it may contain secrets.
# ─────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────

# Path to the SQLite database file. In Docker Compose this points at the
# mounted volume (./data/db); for local development a relative path like
# ./data/db/pkv.sqlite works too. Defaults to `data/db/pkv.sqlite` if unset.
DATABASE_PATH=/app/db/pkv.sqlite

# Port the backend HTTP server listens on (default: 8080).
PORT=8080

# Allowed CORS origins for the backend API. Not used in the default
# single-origin setup (the frontend's nginx proxies /api to the backend, so
# requests are same-origin and never trigger CORS). Only relevant if you run the
# backend on a SEPARATE origin the browser calls directly: then set a
# comma-separated allow-list, e.g. `https://app.example.com`. `*` allows any
# origin (fine on a trusted home network, but it cannot be combined with
# credentialed requests).
CORS_ORIGINS=*

# Optional API key for the backend's `X-API-Key` authentication, used for
# external access via VPN (e.g. Tailscale). Leave empty when you rely solely
# on reverse-proxy Basic Auth inside your home network.
# docker-compose.yml wires this into the backend as `API_KEY=${PKV_API_KEY}`.
PKV_API_KEY=

# ── Frontend ─────────────────────────────────────────────────

# Base URL the BROWSER uses to reach the backend REST API.
#
# LEAVE EMPTY for the default single-origin setup (recommended): the frontend's
# nginx proxies /api to the backend, so the browser only ever talks to its own
# origin. The reverse-proxy HTTP Basic Auth that protects the app then also
# covers the API, and there is no CORS. This is the right choice when the app
# lives behind one hostname (e.g. https://pkv.example.com).
#
# Set it ONLY to point the browser at a SEPARATE backend origin (e.g.
# https://pkv-backend.example.com). It must be reachable from the user's browser
# — NOT the in-compose service name `backend`, which only resolves inside the
# network — and you must then also set PKV_API_KEY (cross-origin Basic Auth is
# not sent by the SPA) and CORS_ORIGINS.
#
# The frontend is a static PWA, so this is baked into the bundle at *build time*
# (docker-compose.yml passes it as a build arg): re-run `docker compose build
# frontend` after changing it, or override it at runtime in the app's settings.
PUBLIC_API_URL=
