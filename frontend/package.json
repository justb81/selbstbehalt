{
  "name": "@selbstbehalt/frontend",
  "version": "0.0.0",
  "private": true,
  "description": "SvelteKit PWA for selbstbehalt (PKV Manager).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "test:coverage": "svelte-kit sync && vitest run --coverage",
    "test:e2e": "vite build && playwright test"
  },
  "dependencies": {
    "@selbstbehalt/shared": "workspace:*",
    "date-fns": "4.1.0",
    "onnxruntime-web": "1.27.0",
    "pdfjs-dist": "^6.1.200",
    "ppu-paddle-ocr": "6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@vite-pwa/sveltekit": "1.1.0",
    "fake-indexeddb": "6.2.5",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "1.3.0",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  }
}
