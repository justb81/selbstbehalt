{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    // SvelteKit's generated config owns module/moduleResolution/paths; here we
    // layer on the repo-wide strictness from ../tsconfig.base.json.
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true
  },
  // Extend (rather than replace) SvelteKit's generated include with the root
  // config/test-setup files it leaves out, so they are type-checked too.
  // vitest-setup.ts registers the jest-dom matcher types used in component tests.
  "include": [
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/env.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest-setup.ts",
    "playwright.config.ts",
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.svelte",
    "e2e/**/*.ts"
  ]
}
