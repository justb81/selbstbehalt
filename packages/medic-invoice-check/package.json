{
  "name": "@selbstbehalt/medic-invoice-check",
  "version": "1.1.0",
  "private": true,
  "description": "Framework-light, backend-free scan-and-check engine for German medical invoices (GOÄ and GOZ): the on-device OCR pipeline, the GOÄ/GOZ/GOT fee-schedule parser validating the full rule set (§5 Steigerungsfaktor limits, code exclusions, Höchstwerte, frequency limits, and more), the versioned fee tables, and the reusable scan + review UI (OCRScanner, InvoiceReview). Consumed by apps/frontend and the GOÄ-Wächter demo.",
  "license": "Apache-2.0",
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lucide/svelte": "^1.23.0",
    "@selbstbehalt/shared": "workspace:*",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "onnxruntime-web": "1.27.0",
    "pdfjs-dist": "^6.1.200",
    "ppu-paddle-ocr": "6.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
