{
  "name": "@selbstbehalt/frontend",
  "version": "1.9.0",
  "private": true,
  "description": "SvelteKit PWA for selbstbehalt (PKV Manager).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "node ../../scripts/copy-ort-wasm.mjs && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "test:coverage": "svelte-kit sync && vitest run --coverage",
    "test:e2e": "vite build && playwright test"
  },
  "dependencies": {
    "@selbstbehalt/medic-invoice-check": "workspace:*",
    "@selbstbehalt/shared": "workspace:*",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "date-fns": "4.4.0",
    "next-themes": "^0.4.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.23.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@vite-pwa/sveltekit": "1.1.0",
    "fake-indexeddb": "6.2.5",
    "jsdom": "^29.1.1",
    "layerchart": "2.0.1",
    "mode-watcher": "^1.1.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-sonner": "^1.1.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "1.3.0",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  }
}
