# Runtime data — generated SQLite databases, uploaded invoice files, etc.
# Version-controlled under data/: the legal-text XML exports (data/input/),
# the fee-schedule JSON Schema (data/schema/) and the format example (data/examples/).
/data/*
!/data/input/
!/data/schema/
!/data/examples/
*.sqlite
*.sqlite3
*.db

