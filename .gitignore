# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.svelte-kit/
.output/
*.tsbuildinfo
# Generated at Docker build time by scripts/generate-frontend-security-headers.mjs
# — the checked-in apps/frontend/security-headers.conf is only the template.
apps/frontend/security-headers.generated.conf

# Test & coverage output
coverage/
playwright-report/
test-results/
.husky/_/

# Environment
.env
.env.*
!.env.example

# Runtime data — generated SQLite databases, uploaded invoice files, etc.
# Version-controlled under data/: the legal-text XML exports (data/input/),
# the fee-schedule JSON Schema (data/schema/) and the format example (data/examples/).
/data/*
!/data/input/
!/data/schema/
!/data/examples/
*.sqlite
*.sqlite3
*.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Reverse-proxy hardening examples (deploy/reverse-proxy, issue #31): local
# secrets and generated certs, never checked in.
deploy/reverse-proxy/traefik/htpasswd
deploy/reverse-proxy/traefik/letsencrypt/
deploy/reverse-proxy/traefik/dynamic/*
!deploy/reverse-proxy/traefik/dynamic/*.example
deploy/reverse-proxy/nginx/htpasswd
deploy/reverse-proxy/nginx/certs/
deploy/reverse-proxy/nginx/certbot-etc/
deploy/reverse-proxy/nginx/certbot-webroot/
