# SPDX-License-Identifier: Apache-2.0
#
# Copy to deploy/reverse-proxy/traefik/.env and adjust:
#
#     cp deploy/reverse-proxy/traefik/.env.example deploy/reverse-proxy/traefik/.env

# Public hostname the app is served under, e.g. pkv.example.com (Option A,
# Let's Encrypt) or a LAN name like pkv.local (Option B, self-signed — see
# README.md). Must resolve to this host from wherever you browse to it.
DOMAIN=

# Only used for Option A (Let's Encrypt). Let's Encrypt sends renewal/expiry
# notices here; any address you control works.
ACME_EMAIL=
